@model IEnumerable<BookRen.Models.CartItem>;

@{
    ViewData["Title"] = "Your cart";
    var currentUrl = @Url.RouteUrl(ViewContext.RouteData.Values);
    int numberItem = 0;
}

<h1>Your cart</h1>

<div>
    <input type="checkbox" name="selectAll" onclick="toggle(this)" id="firstCheckbox" />
    <label>Select all</label>
</div>
<br />

@{
    if (Model is not null)
    {
        foreach (var item in Model)
        {
            numberItem += 1;
            
            <div>
                <input type="checkbox" class="selected-item" value="@item.Id" onclick="toggle(this)" />
                <div>
                    <label>@item.Book.Title</label>
                    <label>@item.Book.Author</label>
                </div>

                <div>
                    <form asp-controller="Cart" asp-action="UpdateItemQuantity" asp-route-id="@item.Id">
                        <input type="number" value="@item.Quantity"
                               onchange="makeUpdateQntBtnVisible(@numberItem.ToString())" min="1" />
                        <input type="submit" value="Update quantity" class="quantity-update" id="qnt-update-@numberItem.ToString()" />
                    </form>
                    <label>Price</label>
                </div>

                <div>
                    <form asp-controller="Cart" asp-action="RemoveItem" asp-route-id="@item.Id">
                        <input type="hidden" name="returnUrl" value="@currentUrl" />
                        <input onclick="return confirm('Are you sure you want to delete the selected item(s)?')" type="submit" value="Remove from Cart" />
                    </form>
                </div>
                <br />
            </div>
        }
        <form asp-controller="Cart" asp-action="RemoveSelectedItems">
            <input type="hidden" name="returnUrl" value="@currentUrl" />
            <input type="hidden" name="ids" value="" id="selected-ids"/>
            <input type="submit" value="Delete selected ones" id="delete-all-btn" onclick="selectItems()" />
        </form>
    }
}