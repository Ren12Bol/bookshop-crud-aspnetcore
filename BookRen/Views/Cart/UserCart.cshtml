@model IEnumerable<BookRen.Models.CartItem>;

@{
    ViewData["Title"] = "Your cart";
    var currentUrl = @Url.RouteUrl(ViewContext.RouteData.Values);
}

<h1>Your cart</h1>

<div>
    <input type="checkbox" name="Select all"/>

    <input type="button" value="Delete selected ones"/>
</div>
@{
    if (Model is not null)
    {
        foreach (var item in Model)
        {
            <div>
                <label>@item.Book.Title</label>
                <label>@item.Book.Author</label>
            </div>

            <div>
                <input type="button" value="-" />
                <label>@item.Quantity</label>
                <input type="button" value="+" />
                <label>Price</label>
            </div>

            <div>
                <form asp-controller="Cart" asp-action="RemoveItem" asp-route-id="@item.Id">
                    <input type="hidden" name="returnUrl" value="@currentUrl" />
                    <input onclick="return confirm('Are you sure you want to delete the selected item(s)?')" type="submit" value="Remove from Cart" />
                </form>
            </div>
        }
    }
}